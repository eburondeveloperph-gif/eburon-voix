# GEMINI_API_KEY: Required for Gemini AI API calls (server + client).
# For client-side features (chat, image gen, voice), also set NEXT_PUBLIC_GEMINI_API_KEY
# or the app will fall back to GEMINI_API_KEY if set in next.config.
GEMINI_API_KEY=your_gemini_api_key
NEXT_PUBLIC_GEMINI_API_KEY=your_gemini_api_key

# Ollama (for chat - local or hosted)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=codemax-beta:latest

# Hugging Face (for Flux image generation)
HF_TOKEN=your_huggingface_token
NEXT_PUBLIC_HF_TOKEN=your_huggingface_token

# Supabase (optional - for chat history, auth, storage)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
